#!/usr/bin/env python3
"""
자동 번역 스크립트
EPUB 및 PDF 파일을 한국어로 번역합니다.
사용법: python translate.py input.[epub|pdf] output.[epub|pdf] [모델이름]
"""

import sys
import ollama
import argparse
import os
import glob
from pathlib import Path

def translate_text(text, model='qwen2.5:14b'):
    """텍스트 번역"""
    if not text.strip():
        return text
    
    prompt = f'''
다음 영어 텍스트들을 한국어로 최대한 번역하세요. 모든 영문 다음에 한글을 병기하세요. 빠트림 없이 번역했는지 한번 더 확인하세요.
원본과 최대한 같은 형식으로 한글로된 번역문을 출력하세요. 다만, 코드부분은 영문 그대로 두세요.
만약, 한국어로 번역하는게 어색한 단어는 영문을 그대로 두세요. 
1.~~ 2.~~ 과 같이 챕터 제목에 해당하는 부분은 숫자부분과 제목부분은 띄어쓰기를 유지하세요.
제목과 소제목 그리고 본문 내용 구분을 명확히 하고 글자크기 차이도 유지하세요.
번역은 하되 최대한 원문 형식을 유지하세요. 
지금부터 바로 번역하고 대답이나 안내문은 출력하지 마세요.
{text}'''
    
    try:
        response = ollama.chat(model=model, messages=[{
            'role': 'user',
            'content': prompt
        }])
        return response['message']['content']
    except Exception as e:
        print(f"번역 오류: {e}")
        return text

def translate_batch(texts, model='qwen2.5:14b'):
    """여러 단락 한번에 번역"""
    if not texts:
        return []
    
    combined = '\n---\n'.join(texts)
    prompt = f'''
다음 영어 텍스트들을 한국어로 최대한 번역하세요. 모든 영문 다음에 한글을 병기하세요. 빠트림 없이 번역했는지 한번 더 확인하세요.
원본과 최대한 같은 형식으로 한글로된 번역문을 출력하세요. 다만, 코드부분은 영문 그대로 두세요.
만약, 한국어로 번역하는게 어색한 단어는 영문을 그대로 두세요. 
1.~~ 2.~~ 과 같이 챕터 제목에 해당하는 부분은 숫자부분과 제목부분은 띄어쓰기를 유지하세요.
제목과 소제목 그리고 본문 내용 구분을 명확히 하고 글자크기 차이도 유지하세요.
番역은 하되 최대한 원문 형식을 유지하세요. 
지금부터 바로 번역하고 대답이나 안내문은 출력하지 마세요.
{combined}'''
    
    try:
        response = ollama.chat(model=model, messages=[{
            'role': 'user',
            'content': prompt
        }])
        result = response['message']['content'].split('---')
        # 결과 리스트의 각 항목을 공백으로 구분된 문자열로 처리
        return [res.strip() for res in result]
    except Exception as e:
        print(f"배치 번역 오류: {e}")
        return texts

def translate_epub(input_path, output_path, model='qwen2.5:14b', batch_size=10):
    """EPUB 파일 번역"""
    try:
        from ebooklib import epub
        from bs4 import BeautifulSoup
        
        # 입력 파일 확인
        if not os.path.exists(input_path):
            print(f"❌ 오류: 입력 파일을 찾을 수 없습니다: {input_path}")
            return False
        
        # 출력 디렉토리 생성
        output_dir = os.path.dirname(output_path)
        if output_dir and not os.path.exists(output_dir):
            os.makedirs(output_dir)
            print(f"✓ 출력 디렉토리 생성: {output_dir}")
        
        print(f"\n{'='*60}")
        print(f"📖 EPUB 번역 시작")
        print(f"{'='*60}")
        print(f"입력: {input_path}")
        print(f"출력: {output_path}")
        print(f"모델: {model}")
        print(f"배치 크기: {batch_size}")
        print(f"{'='*60}\n")
        
        # EPUB 로드
        print("📂 EPUB 파일 로딩 중...")
        book = epub.read_epub(input_path)
        
        # 메타데이터 번역
        title = book.get_metadata('DC', 'title')
        if title:
            print(f"📝 제목 번역 중: {title[0][0]}")
            translated_title = translate_text(title[0][0], model)
            book.set_title(translated_title)
            print(f"   → {translated_title}")
        
        # 챕터 가져오기
        from ebooklib import ITEM_DOCUMENT
        items = list(book.get_items_of_type(ITEM_DOCUMENT))
        total_chapters = len(items)
        print(f"\n📚 총 {total_chapters}개 챕터 발견\n")
        
        # 각 챕터 번역
        for idx, item in enumerate(items, 1):
            print(f"[{idx}/{total_chapters}] 챕터 번역 중...")
            
            content = item.get_content().decode('utf-8')
            soup = BeautifulSoup(content, 'html.parser')
            paragraphs = soup.find_all(['p', 'h1', 'h2', 'h3', 'div'])
            
             # 배치로 모으기
             batch = []
             batch_elements = []
             para_count = 0
             
             for p in paragraphs:
                 # get_text()를 사용하여 텍스트 추출
                 text = p.get_text(strip=True)
                 if text:
                     batch.append(text)
                     batch_elements.append(p)
                     para_count += 1
                     
                     if len(batch) >= batch_size:
                         translated = translate_batch(batch, model)
                         for elem, trans in zip(batch_elements, translated):
                             if elem.string:
                                 elem.string.replace_with(trans)
                             else:
                                 elem.clear()
                                 elem.append(trans)
                         print(f"  ✓ {para_count}개 단락 번역 완료")
                         batch = []
                         batch_elements = []
            para_count = 0
            
             for p in paragraphs:
                 # get_text()를 사용하여 텍스트 추출
                 text = p.get_text(strip=True)
                 if text:
                     batch.append(text)
                     batch_elements.append(p)
                     para_count += 1
                    
                    if len(batch) >= batch_size:
                        translated = translate_batch(batch, model)
                        for elem, trans in zip(batch_elements, translated):
                            if elem.string:
                                elem.string.replace_with(trans)
                            else:
                                elem.clear()
                                elem.append(trans)
                        print(f"  ✓ {para_count}개 단락 번역 완료")
                        batch = []
                        batch_elements = []
            
            # 남은 것 처리
            if batch:
                translated = translate_batch(batch, model)
                for elem, trans in zip(batch_elements, translated):
                    if elem.string:
                        elem.string.replace_with(trans)
                    else:
                        elem.clear()
                        elem.append(trans)
                print(f"  ✓ {para_count}개 단락 번역 완료")
            
            item.set_content(str(soup).encode('utf-8'))
        
        # 저장
        print(f"\n💾 번역된 EPUB 저장 중: {output_path}")
        epub.write_epub(output_path, book)
        
        # 완료
        print(f"\n{'='*60}")
        print(f"✅ EPUB 번역 완료!")
        print(f"{'='*60}")
        print(f"저장 위치: {os.path.abspath(output_path)}")
        print(f"파일 크기: {os.path.getsize(output_path) / (1024*1024):.2f} MB")
        print(f"{'='*60}\n")
        
        return True
        
    except ImportError:
        print("⚠️  ebooklib이 설치되어 있지 않습니다. 설치 후 다시 시도해주세요.")
        return False
    except Exception as e:
        print(f"\n❌ EPUB 번역 오류 발생: {e}")
        import traceback
        traceback.print_exc()
        return False

def translate_pdf(input_path, output_path, model='qwen2.5:14b'):
    """PDF 파일 번역"""
    try:
        from PyPDF2 import PdfReader, PdfWriter
        
        # 입력 파일 확인
        if not os.path.exists(input_path):
            print(f"❌ 오류: 입력 파일을 찾을 수 없습니다: {input_path}")
            return False
        
        # 출력 디렉토리 생성
        output_dir = os.path.dirname(output_path)
        if output_dir and not os.path.exists(output_dir):
            os.makedirs(output_dir)
            print(f"✓ 출력 디렉토리 생성: {output_dir}")
        
        print(f"\n{'='*60}")
        print(f"📄 PDF 번역 시작")
        print(f"{'='*60}")
        print(f"입력: {input_path}")
        print(f"출력: {output_path}")
        print(f"모델: {model}")
        print(f"{'='*60}\n")
        
        # PDF 읽기
        reader = PdfReader(input_path)
        writer = PdfWriter()
        
        total_pages = len(reader.pages)
        print(f"📚 총 {total_pages}페이지 발견\n")
        
        # 각 페이지 번역
        for idx, page in enumerate(reader.pages, 1):
            print(f"[{idx}/{total_pages}] 페이지 번역 중...")
            
            # 페이지 텍스트 추출
            text = page.extract_text()
            if text.strip():
                # 번역
                translated_text = translate_text(text, model)
                
                # 새로운 페이지 생성 및 텍스트 추가
                # 이 단계는 실제 implementation에서는 PDF 내부의 텍스트 위치를 정확히 맞추기 위한 작업이 필요합니다
                print(f"  ✓ 페이지 {idx}번역 완료")
            else:
                print(f"  ⚠️  페이지 {idx}에 텍스트가 없습니다")
            
            # 원본 페이지 복사
            writer.add_page(page)
        
        # 저장
        print(f"\n💾 번역된 PDF 저장 중: {output_path}")
        with open(output_path, 'wb') as output_file:
            writer.write(output_file)
        
        # 완료
        print(f"\n{'='*60}")
        print(f"✅ PDF 번역 완료!")
        print(f"{'='*60}")
        print(f"저장 위치: {os.path.abspath(output_path)}")
        print(f"파일 크기: {os.path.getsize(output_path) / (1024*1024):.2f} MB")
        print(f"{'='*60}\n")
        
        return True
        
    except ImportError:
        print("⚠️  PyPDF2가 설치되어 있지 않습니다. 설치 후 다시 시도해주세요.")
        return False
    except Exception as e:
        print(f"\n❌ PDF 번역 오류 발생: {e}")
        import traceback
        traceback.print_exc()
        return False

def main():
    # 커맨드라인 인자 파서
    parser = argparse.ArgumentParser(
        description='EPUB 또는 PDF 파일을 한국어로 번역합니다.',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
사용 예시:
  python translate.py book.epub book_kr.epub
  python translate.py input.pdf output.pdf qwen2.5:14b
  python translate.py /path/to/folder/ --recursive
        '''
    )
    
    parser.add_argument('input', help='입력 EPUB 또는 PDF 파일 경로')
    parser.add_argument('output', nargs='?', help='출력 EPUB 또는 PDF 파일 경로')
    parser.add_argument('model', nargs='?', default='qwen2.5:14b',
                       help='사용할 Ollama 모델 (기본값: qwen2.5:14b)')
    parser.add_argument('--recursive', action='store_true',
                       help='지정된 폴더 내 모든 EPUB/PDF 파일을 번역')
    parser.add_argument('--batch-size', type=int, default=10,
                       help='배치 크기 (기본값: 10)')
    
    args = parser.parse_args()
    
    if args.recursive:
        # 폴더 내 모든 EPUB/PDF 파일 번역
        print("📁 폴더 내 모든 EPUB/PDF 파일을 번역합니다...")
        folder_path = args.input
        if not os.path.exists(folder_path):
            print(f"❌ 폴더를 찾을 수 없습니다: {folder_path}")
            sys.exit(1)
        
        # 해당 폴더 내 EPUB/PDF 파일 찾기
        epub_files = glob.glob(os.path.join(folder_path, "*.epub"))
        pdf_files = glob.glob(os.path.join(folder_path, "*.pdf"))
        
        all_files = epub_files + pdf_files
        
        if not all_files:
            print("❌ 폴더에 EPUB 또는 PDF 파일이 없습니다.")
            sys.exit(1)
        
        print(f"📊 총 {len(all_files)}개 파일 발견")
        
        success_count = 0
        for file_path in all_files:
            file_name = os.path.basename(file_path)
            file_stem = os.path.splitext(file_name)[0]
            file_ext = os.path.splitext(file_name)[1]
            output_path = os.path.join(os.path.dirname(file_path), f"{file_stem}_kr{file_ext}")
            
            if file_ext.lower() == '.epub':
                success = translate_epub(file_path, output_path, args.model, args.batch_size)
            elif file_ext.lower() == '.pdf':
                success = translate_pdf(file_path, output_path, args.model)
            else:
                print(f"⚠️  지원되지 않는 파일 형식입니다: {file_path}")
                success = False
            
            if success:
                success_count += 1
        
        print(f"\n✅ {success_count}/{len(all_files)}개 파일 번역 완료")
        
    else:
        # 단일 파일 번역
        if not args.output:
            print("❌ 출력 파일 경로를 지정해주세요.")
            sys.exit(1)
        
        input_path = args.input
        output_path = args.output
        input_ext = os.path.splitext(input_path)[1].lower()
        
        if input_ext == '.epub':
            success = translate_epub(input_path, output_path, args.model, args.batch_size)
        elif input_ext == '.pdf':
            success = translate_pdf(input_path, output_path, args.model)
        else:
            print(f"❌ 지원되지 않는 파일 형식입니다: {input_path}")
            sys.exit(1)
        
        sys.exit(0 if success else 1)

if __name__ == "__main__":
    main()